{
  "name": "@dev-anywhere/shared",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && rm -f dist/.tsbuildinfo && tsc -p tsconfig.build.json --outDir dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
