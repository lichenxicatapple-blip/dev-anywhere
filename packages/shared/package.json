{
  "name": "@cc-anywhere/shared",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && rm -f dist/.tsbuildinfo && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6",
    "nanoid": "^5.1.7"
  }
}
