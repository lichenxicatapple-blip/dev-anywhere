{
  "name": "dev-anywhere",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint . && pnpm run lint:source-refs",
    "lint:source-refs": "node scripts/quality/check-source-comment-refs.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bash scripts/test/vitest.sh",
    "test:integration": "TEST_SCOPE=integration vitest run",
    "typecheck": "tsc -b",
    "knip": "knip",
    "quality:check": "bash scripts/quality/check.sh",
    "build:icons": "pnpm --filter @dev-anywhere/web run build:icons",
    "release": "bash scripts/release/release.sh",
    "release:check": "bash scripts/release/check.sh",
    "release:smoke": "bash scripts/release/smoke.sh",
    "dev:web": "bash scripts/dev/web.sh",
    "dev:restart": "scripts/dev/restart.sh",
    "dev:health": "scripts/dev/health.sh",
    "dev:relay:restart": "bash scripts/dev/relay-restart.sh",
    "dev:chaos": "bash scripts/dev/chaos.sh",
    "tools:emu-debug": "node scripts/tools/emu-debug.mjs",
    "tools:ipad-debug": "node scripts/tools/ipad-webkit-debug.mjs",
    "test:unit": "bash scripts/test/unit.sh",
    "test:layout": "bash scripts/test/layout.sh",
    "test:pc": "bash scripts/test/pc.sh",
    "test:mobile": "bash scripts/test/mobile-parallel.sh",
    "test:mobile:serial": "bash scripts/test/mobile.sh",
    "test:mobile:emulators:create": "bash scripts/test/mobile-emulators.sh create",
    "test:mobile:emulators:start": "bash scripts/test/mobile-emulators.sh start",
    "test:mobile:emulators:stop": "bash scripts/test/mobile-emulators.sh stop",
    "test:mobile:emulators:list": "bash scripts/test/mobile-emulators.sh list",
    "dev-anywhere": "node apps/proxy/dist/index.js",
    "proxy": "pnpm --filter @dev-anywhere/proxy run dev --",
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.4.0",
    "knip": "^6.5.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@esbuild/*",
      "node-pty"
    ],
    "overrides": {
      "@types/react": "^19.1.6",
      "@types/react-dom": "^19.1.6"
    }
  }
}
