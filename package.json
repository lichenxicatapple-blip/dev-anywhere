{
  "name": "cc-anywhere",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "TEST_SCOPE=unit vitest run",
    "test:integration": "TEST_SCOPE=integration vitest run",
    "typecheck": "tsc -b",
    "cc-anywhere": "node apps/proxy/dist/index.js",
    "proxy": "INIT_CWD=$PWD pnpm --filter @lichenxi.cat/cc-anywhere run dev --",
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@esbuild/*",
      "node-pty"
    ],
    "overrides": {
      "@types/react": "^19.1.6",
      "@types/react-dom": "^19.1.6"
    }
  }
}
