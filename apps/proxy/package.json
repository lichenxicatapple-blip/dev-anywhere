    "@cc-anywhere/shared": "workspace:*",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "commander": "^14.0.3",
    "nanoid": "^5.1.7",
    "node-pty": "^1.1.0",
    "pino": "^10.3.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1"
  }
}
