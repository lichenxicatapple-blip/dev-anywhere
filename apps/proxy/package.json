{
  "name": "@cc-anywhere/proxy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "bin": {
    "cc-anywhere": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "serve": "tsx src/serve.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
