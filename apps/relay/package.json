{
  "name": "@dev-anywhere/relay",
  "version": "0.4.28",
  "description": "Relay server for DEV Anywhere — bridges local AI CLI proxies to remote web clients via WebSocket.",
  "keywords": [
    "claude-code",
    "relay",
    "websocket",
    "server",
    "dev-anywhere"
  ],
  "license": "MIT",
  "author": "catli",
  "homepage": "https://github.com/lichenxicatapple-blip/dev-anywhere",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lichenxicatapple-blip/dev-anywhere.git",
    "directory": "apps/relay"
  },
  "bugs": {
    "url": "https://github.com/lichenxicatapple-blip/dev-anywhere/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "dev-anywhere-relay": "./dist/index.js"
  },
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "build": "tsup && rm -f tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "express": "^5.1.0",
    "nanoid": "^5.1.7",
    "pino": "^10.3.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dev-anywhere/shared": "workspace:*",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.30",
    "@types/ws": "^8.18.1",
    "vitest": "^4.1.2"
  }
}
