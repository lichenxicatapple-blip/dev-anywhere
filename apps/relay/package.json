{
  "name": "@cc-anywhere/relay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "build": "tsup && rm -f tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cc-anywhere/shared": "workspace:*",
    "ws": "^8.20.0",
    "express": "^5.1.0",
    "nanoid": "^5.1.7"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.30",
    "vitest": "^4.1.2"
  }
}
